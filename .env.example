# =====================================================================
# Ourchat environment configuration
# ---------------------------------------------------------------------
# EVERYTHING here is OPTIONAL. With no .env file the site runs in a
# friendly "demo mode": guest-name login + mock Discord online members.
# Fill these in to switch on real Discord login + the live widget.
# Copy this file to ".env" and edit.
# =====================================================================

# --- Discord OAuth ("Sign in with Discord") ---
# Create an application at https://discord.com/developers/applications
# OAuth2 -> add redirect: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Discord server (guild) ---
# Enable "Server Widget" in Server Settings -> Widget, then copy the Server ID.
# Right-click your server icon -> Copy Server ID (needs Developer Mode on).
DISCORD_GUILD_ID=
# A permanent invite link to your server (used by the big "Join" button).
DISCORD_INVITE_URL=https://discord.gg/your-invite

# --- NextAuth ---
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
