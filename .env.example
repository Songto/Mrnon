# =====================================================================
# Ourchat environment configuration  —  copy this file to ".env"
# =====================================================================
# With NOTHING filled in, the site runs in friendly "demo mode":
# guest-name login, mock Discord widget, data saved to a local file.
# Fill these in to turn on: a real DATABASE, DISCORD login, EMAIL register.
# =====================================================================

# --- 1) DATABASE (keeps profiles/seeds/badges/chat forever) ----------
# Get a FREE Postgres at https://neon.tech (no credit card).
# Copy the connection string it gives you and paste it here.
# Leave blank to use the local file (resets on each redeploy).
DATABASE_URL=

# --- 2) NextAuth (needed for ANY login) ------------------------------
# A long random secret. Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=
# Your live site URL (use http://localhost:3000 while testing locally).
NEXTAUTH_URL=https://your-domain.com

# --- 3) DISCORD login ("Sign in with Discord") -----------------------
# Create an app at https://discord.com/developers/applications
# OAuth2 -> Redirects -> add BOTH:
#   http://localhost:3000/api/auth/callback/discord
#   https://your-domain.com/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- 4) Discord server widget (optional, for the live members box) ---
# Server Settings -> Widget -> enable, then copy the Server ID.
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=https://discord.gg/sDgzXBNjx8

# Email register needs NOTHING extra here — it uses the database above.
